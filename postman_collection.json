{
  "info": {
    "name": "Secure Patient Records API",
    "description": "Postman collection for testing the Secure Patient Records API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login as Viewer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\": \"viewer\", \"password\": \"password\"}"
        },
        "url": {
          "raw": "https://localhost:8443/auth/login",
          "protocol": "https",
          "host": ["localhost"],
          "port": "8443",
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Login as Editor",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\": \"editor\", \"password\": \"password\"}"
        },
        "url": {
          "raw": "https://localhost:8443/auth/login",
          "protocol": "https",
          "host": ["localhost"],
          "port": "8443",
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Create Patient (Editor Only)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{editor_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Alice Johnson\", \"age\": 45, \"diagnosis\": \"Hypertension\"}"
        },
        "url": {
          "raw": "https://localhost:8443/patients",
          "protocol": "https",
          "host": ["localhost"],
          "port": "8443",
          "path": ["patients"]
        }
      }
    },
    {
      "name": "Get All Patients",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{viewer_token}}"
          }
        ],
        "url": {
          "raw": "https://localhost:8443/patients",
          "protocol": "https",
          "host": ["localhost"],
          "port": "8443",
          "path": ["patients"]
        }
      }
    },
    {
      "name": "Get Single Patient",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{editor_token}}"
          }
        ],
        "url": {
          "raw": "https://localhost:8443/patients/1",
          "protocol": "https",
          "host": ["localhost"],
          "port": "8443",
          "path": ["patients", "1"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "viewer_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "editor_token",
      "value": "",
      "type": "string"
    }
  ]
}